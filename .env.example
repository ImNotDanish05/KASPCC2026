# ==========================================
# DATABASE SETTINGS
# ==========================================

# Connection pooling URL used by Prisma Client during runtime
# E.g., postgresql://[user]:[password]@[host]:[port]/[db]?pgbouncer=true
DATABASE_URL=""

# Direct connection to the database used by Prisma for migrations (npx prisma migrate / db push)
# If Direct connection doesn't work, use Session pooler
# E.g., postgresql://[user]:[password]@[host]:[port]/[db]
DIRECT_URL=""


# ==========================================
# SUPABASE SETTINGS (Storage, Edge Functions, etc.)
# ==========================================

# The public URL of your Supabase project (from Project Settings -> API)
NEXT_PUBLIC_SUPABASE_URL=""

# The public anon key (used in the browser for public buckets/policies)
NEXT_PUBLIC_SUPABASE_ANON_KEY=""

# The secret service role key (used server-side to bypass RLS for uploads)
# WARNING: NEVER expose this key in the browser/frontend!
SUPABASE_SERVICE_ROLE_KEY=""


# ==========================================
# AUTHENTICATION SETTINGS
# ==========================================

# Secret used to encrypt/sign session cookies (use a long, random string)
# You can generate one via: `openssl rand -base64 32`
AUTH_SECRET=""
NEXTAUTH_SECRET=""


# ==========================================
# APPLICATION & SEEDING SETTINGS
# ==========================================

# Environment mode: "local" | "production" | "development"
NODE_ENV="local"

# Default password for accounts generated via `npx prisma db seed` in local environment
PASSWORD_LOCAL="password"

# Default password for accounts generated via `npx prisma db seed` in production environment
# MUST be strong and hard to guess!
PASSWORD_PRODUCTION=""
